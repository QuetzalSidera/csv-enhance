{
  "name": "csvx",
  "scopeName": "source.csvx",
  "patterns": [
    { "include": "#comments" },
    { "include": "#func-signature" },
    { "include": "#directive-lines" },
    { "include": "#meta-entry" },
    { "include": "#target-line" },
    { "include": "#deps-line" },
    { "include": "#order-line" },
    { "include": "#group-line" },
    { "include": "#exports-line" },
    { "include": "#path-line" },
    { "include": "#plot-field-line" },
    { "include": "#title-line" },
    { "include": "#compute-assignment" },
    { "include": "#typed-properties" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.sheet",
          "match": "#.*$"
        }
      ]
    },
    "directive-lines": {
      "patterns": [
        {
          "name": "meta.directive.named-block.sheet",
          "match": "^\\s*(@)(table|compute|window|plot)\\s+([\\p{L}_][\\p{L}\\p{N}\\p{M}_-]*)\\s*$",
          "captures": {
            "1": {
              "name": "punctuation.definition.keyword.sheet"
            },
            "2": {
              "name": "keyword.control.directive.sheet"
            },
            "3": {
              "name": "entity.name.type.class.sheet"
            }
          }
        },
        {
          "name": "meta.directive.plugin.sheet",
          "match": "^\\s*(@)(plugin)\\s+([\\p{L}_][\\p{L}\\p{N}\\p{M}_-]*)\\s*$",
          "captures": {
            "1": {
              "name": "punctuation.definition.keyword.sheet"
            },
            "2": {
              "name": "keyword.control.directive.sheet"
            },
            "3": {
              "name": "entity.name.type.class.sheet"
            }
          }
        },
        {
          "name": "meta.directive.simple.sheet",
          "match": "^\\s*(@)(meta|func)\\b",
          "captures": {
            "1": {
              "name": "punctuation.definition.keyword.sheet"
            },
            "2": {
              "name": "keyword.control.directive.sheet"
            }
          }
        }
      ]
    },
    "func-signature": {
      "patterns": [
        {
          "name": "meta.function.signature.sheet",
          "begin": "^\\s*(@func)\\s+([\\p{L}_][\\p{L}\\p{N}\\p{M}_]*)\\s*(\\()",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.directive.sheet"
            },
            "2": {
              "name": "entity.name.function.sheet"
            },
            "3": {
              "name": "punctuation.section.parameters.begin.sheet"
            }
          },
          "end": "(\\))\\s*(=>)\\s*(?:((?:dynamic|string|number|boolean|null))|(\\[(?:(row|col):)?(dynamic|string|number|boolean|null)\\]))\\s*$",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.parameters.end.sheet"
            },
            "2": {
              "name": "keyword.operator.type.annotation.sheet"
            },
            "3": {
              "name": "storage.type.primitive.sheet"
            },
            "4": {
              "name": "meta.return-type.vector.sheet"
            },
            "5": {
              "name": "storage.modifier.sheet"
            },
            "6": {
              "name": "storage.type.primitive.sheet"
            }
          },
          "patterns": [
            { "include": "#typed-parameters" },
            {
              "name": "punctuation.separator.parameter.sheet",
              "match": ","
            }
          ]
        }
      ]
    },
    "meta-entry": {
      "patterns": [
        {
          "name": "meta.mapping.meta.sheet",
          "match": "^\\s*([\\p{L}_][\\p{L}\\p{N}\\p{M}_]*)\\s*(:)",
          "captures": {
            "1": {
              "name": "variable.object.property.sheet"
            },
            "2": {
              "name": "punctuation.separator.key-value.sheet"
            }
          }
        }
      ]
    },
    "target-line": {
      "patterns": [
        {
          "name": "meta.mapping.target.sheet",
          "begin": "^\\s*(target)\\s*(:)",
          "beginCaptures": {
            "1": {
              "name": "variable.object.property.sheet"
            },
            "2": {
              "name": "punctuation.separator.key-value.sheet"
            }
          },
          "end": "$",
          "patterns": [
            { "include": "#typed-properties" },
            {
              "name": "punctuation.separator.sequence.sheet",
              "match": ","
            }
          ]
        }
      ]
    },
    "deps-line": {
      "patterns": [
        {
          "name": "meta.mapping.deps.sheet",
          "begin": "^\\s*(deps)\\s*(:)",
          "beginCaptures": {
            "1": {
              "name": "variable.object.property.sheet"
            },
            "2": {
              "name": "punctuation.separator.key-value.sheet"
            }
          },
          "end": "$",
          "patterns": [
            {
              "name": "variable.other.readwrite.sheet",
              "match": "[\\p{L}_][\\p{L}\\p{N}\\p{M}_]*"
            },
            {
              "name": "punctuation.separator.sequence.sheet",
              "match": ","
            }
          ]
        }
      ]
    },
    "identifier-list": {
      "patterns": [
        {
          "name": "variable.other.readwrite.sheet",
          "match": "[\\p{L}_][\\p{L}\\p{N}\\p{M}_]*"
        },
        {
          "name": "punctuation.separator.sequence.sheet",
          "match": ","
        }
      ]
    },
    "order-line": {
      "patterns": [
        {
          "name": "meta.mapping.order.sheet",
          "begin": "^\\s*(order)\\s*(:)",
          "beginCaptures": {
            "1": {
              "name": "variable.object.property.sheet"
            },
            "2": {
              "name": "punctuation.separator.key-value.sheet"
            }
          },
          "end": "$",
          "patterns": [
            { "include": "#identifier-list" }
          ]
        }
      ]
    },
    "group-line": {
      "patterns": [
        {
          "name": "meta.mapping.group.sheet",
          "begin": "^\\s*(group)\\s*(:)",
          "beginCaptures": {
            "1": {
              "name": "variable.object.property.sheet"
            },
            "2": {
              "name": "punctuation.separator.key-value.sheet"
            }
          },
          "end": "$",
          "patterns": [
            { "include": "#identifier-list" }
          ]
        }
      ]
    },
    "exports-line": {
      "patterns": [
        {
          "name": "meta.mapping.exports.sheet",
          "begin": "^\\s*(exports)\\s*(:)",
          "beginCaptures": {
            "1": {
              "name": "variable.object.property.sheet"
            },
            "2": {
              "name": "punctuation.separator.key-value.sheet"
            }
          },
          "end": "$",
          "patterns": [
            {
              "name": "entity.name.function.sheet",
              "match": "[\\p{L}_][\\p{L}\\p{N}\\p{M}_]*"
            },
            {
              "name": "punctuation.separator.sequence.sheet",
              "match": ","
            }
          ]
        }
      ]
    },
    "path-line": {
      "patterns": [
        {
          "name": "meta.mapping.path.sheet",
          "match": "^\\s*(path)\\s*(:)(.*)$",
          "captures": {
            "1": {
              "name": "variable.object.property.sheet"
            },
            "2": {
              "name": "punctuation.separator.key-value.sheet"
            },
            "3": {
              "name": "string.unquoted.sheet"
            }
          }
        }
      ]
    },
    "plot-field-line": {
      "patterns": [
        {
          "name": "meta.mapping.plot-field.sheet",
          "begin": "^\\s*(x|y|color)\\s*(:)",
          "beginCaptures": {
            "1": {
              "name": "variable.object.property.sheet"
            },
            "2": {
              "name": "punctuation.separator.key-value.sheet"
            }
          },
          "end": "$",
          "patterns": [
            {
              "name": "variable.other.readwrite.sheet",
              "match": "[\\p{L}_][\\p{L}\\p{N}\\p{M}_]*"
            }
          ]
        }
      ]
    },
    "title-line": {
      "patterns": [
        {
          "name": "meta.mapping.title.sheet",
          "match": "^\\s*(title)\\s*(:)(.*)$",
          "captures": {
            "1": {
              "name": "variable.object.property.sheet"
            },
            "2": {
              "name": "punctuation.separator.key-value.sheet"
            },
            "3": {
              "name": "string.unquoted.sheet"
            }
          }
        }
      ]
    },
    "compute-assignment": {
      "patterns": [
        {
          "name": "meta.assignment.sheet",
          "begin": "^\\s*([\\p{L}_][\\p{L}\\p{N}\\p{M}_]*)(?:\\[(?:(row|col):)?(dynamic|string|number|boolean|null)\\])?\\s*(=)",
          "beginCaptures": {
            "1": {
              "name": "variable.other.member.sheet"
            },
            "2": {
              "name": "storage.modifier.sheet"
            },
            "3": {
              "name": "storage.type.primitive.sheet"
            },
            "4": {
              "name": "keyword.operator.assignment.sheet"
            }
          },
          "end": "$",
          "patterns": [
            { "include": "#expressions" }
          ]
        }
      ]
    },
    "typed-properties": {
      "patterns": [
        {
          "name": "meta.typed.property.sheet",
          "match": "([\\p{L}_][\\p{L}\\p{N}\\p{M}_]*)(\\[)(?:(row|col):)?(dynamic|string|number|boolean|null)(\\])",
          "captures": {
            "1": {
              "name": "variable.other.member.sheet"
            },
            "2": {
              "name": "punctuation.definition.type.begin.sheet"
            },
            "3": {
              "name": "storage.modifier.sheet"
            },
            "4": {
              "name": "storage.type.primitive.sheet"
            },
            "5": {
              "name": "punctuation.definition.type.end.sheet"
            }
          }
        }
      ]
    },
    "typed-parameters": {
      "patterns": [
        {
          "name": "meta.typed.parameter.sheet",
          "match": "([\\p{L}_][\\p{L}\\p{N}\\p{M}_]*)(\\[)(?:(row|col):)?(dynamic|string|number|boolean|null)(\\])",
          "captures": {
            "1": {
              "name": "variable.parameter.sheet"
            },
            "2": {
              "name": "punctuation.definition.type.begin.sheet"
            },
            "3": {
              "name": "storage.modifier.sheet"
            },
            "4": {
              "name": "storage.type.primitive.sheet"
            },
            "5": {
              "name": "punctuation.definition.type.end.sheet"
            }
          }
        }
      ]
    },
    "expressions": {
      "patterns": [
        {
          "name": "constant.numeric.sheet",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        },
        {
          "name": "constant.language.boolean.sheet",
          "match": "\\btrue\\b|\\bfalse\\b"
        },
        {
          "name": "constant.language.null.sheet",
          "match": "\\bnull\\b"
        },
        {
          "name": "support.function.builtin.sheet",
          "match": "(?<![\\p{L}\\p{N}\\p{M}_])(if|coalesce|and|or|current|lag|lead|first|last|row_number|rank|cumsum)(?=\\s*\\()"
        },
        {
          "name": "meta.function-call.plugin.sheet",
          "match": "([\\p{L}_][\\p{L}\\p{N}\\p{M}_]*)(\\.)([\\p{L}_][\\p{L}\\p{N}\\p{M}_]*)(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "entity.name.type.sheet"
            },
            "2": {
              "name": "punctuation.accessor.dot.sheet"
            },
            "3": {
              "name": "entity.name.function.sheet"
            }
          }
        },
        {
          "name": "entity.name.function.sheet",
          "match": "([\\p{L}_][\\p{L}\\p{N}\\p{M}_]*)(?=\\s*\\()"
        },
        {
          "name": "variable.other.readwrite.sheet",
          "match": "[\\p{L}_][\\p{L}\\p{N}\\p{M}_]*"
        },
        {
          "name": "keyword.operator.arithmetic.sheet",
          "match": "[+\\-*/=]"
        },
        {
          "name": "punctuation.separator.sequence.sheet",
          "match": ","
        },
        {
          "name": "punctuation.section.group.begin.sheet",
          "match": "\\("
        },
        {
          "name": "punctuation.section.group.end.sheet",
          "match": "\\)"
        }
      ]
    }
  }
}
